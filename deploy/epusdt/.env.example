# epusdt sidecar 环境变量 — 复制为 .env 后填真实值
#
# DAOF-CPA W-2 phase（2026-05-21）
#
# 字段说明参考上游 https://github.com/GMWalletApp/epusdt/blob/master/src/.env.example
# 这里只列 DAOF 集成需要的核心字段，其余使用 epusdt 默认即可。

# ── 应用 ──────────────────────────────────────────────
app_name=epusdt
app_uri=http://localhost:8000
http_listen=:8000
log_level=info

# ── 安装首次引导 token（重要：默认关闭防裸奔）─────────────────────────────────
#
# W-3 review M-3 防御：首次启动前必须先生成强 install_token，再临时打开 install=true
# 完成 admin 引导。如果默认 install=true 且 install_token 为空，攻击者扫到端口可直接
# 通过 /install 路径接管 epusdt。
#
# 推荐流程：
#   1. 生成 64-char 随机串：openssl rand -hex 32
#   2. 把 install_token 取消注释填上面那串
#   3. 临时 install=true 启动
#   4. 浏览器 http://localhost:8000/install?token=<your-token> 设 admin 密码
#   5. 完成后 install=false 重启
install=false
# install_token=<run "openssl rand -hex 32" and paste here>

# ── 数据库 ────────────────────────────────────────────
# SQLite 简化部署；高频场景切 MySQL（取消下方注释）
db_type=sqlite
runtime_sqlite_filename=epusdt-runtime.db

# db_type=mysql
# mysql_host=mysql
# mysql_port=3306
# mysql_user=root
# mysql_password=change-me
# mysql_database=epusdt

# ── 钱包收款地址（核心！）────────────────────────────────
# 这些是 admin 后台配置的字段，不是 .env，但部署前必须准备好：
#   TRC20 (TRON):     <YOUR_TRC20_ADDRESS>
#   ERC20 (Ethereum): <YOUR_ERC20_ADDRESS>
#   BEP20 (BSC):      <YOUR_BEP20_ADDRESS>
#   Polygon:          <YOUR_POLYGON_ADDRESS>
#
# 注：epusdt 用静态地址 + 金额尾数（0.0001）区分订单，所以同一钱包可服务多用户。
# 私钥不进 epusdt（watch-only 模式）。
# 真实地址应在 epusdt admin 后台首次引导时录入，不要写在 git 仓库内。

# ── 链上 RPC（默认公开节点，生产建议自建或买）─────────────
# tron_rpc=https://api.trongrid.io
# eth_rpc=https://mainnet.infura.io/v3/<YOUR_KEY>
# bsc_rpc=https://bsc-dataseed.binance.org
# polygon_rpc=https://polygon-rpc.com

# ── 订单管理 ─────────────────────────────────────────
order_expiration_time=10              # 订单 10 分钟过期
callback_retry_base_seconds=5         # 回调失败 5s 起步指数退避
order_notice_max_retry=10             # 最大重试 10 次

# ── 队列 ─────────────────────────────────────────────
queue_concurrency=10
queue_poll_interval_ms=1000

# ── 日志 ─────────────────────────────────────────────
log_save_path=./logs
log_max_size=32                       # MB
log_max_age=7                         # 天
max_backups=3
